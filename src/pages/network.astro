---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

const networkMembers = [
  {
    name: 'California',
    subdomain: 'california.opuspopuli.org',
    status: 'development',
    note: 'Coming 2026',
  },
];

const benefits = [
  { title: 'Shared identity', description: 'Optional *.opuspopuli.org subdomain for your community' },
  { title: 'Collective improvements', description: 'What one community builds, all communities gain' },
  { title: 'Mutual support', description: 'Learn from and help other communities doing the same work' },
  { title: 'Complete sovereignty', description: 'Full control over your data, infrastructure, and governance' },
];

const trustMechanisms = [
  {
    title: 'Prompt lock',
    description: 'Every node gets its analysis prompts from a central, private service. Nodes cannot modify, override, or inject their own prompts. This ensures identical analytical methodology across the entire network.',
  },
  {
    title: 'Cryptographic verification',
    description: 'Every prompt is hashed. Nodes can verify they received an authentic, unmodified prompt. Auditors can verify any analysis was produced with a certified prompt.',
  },
  {
    title: 'Canary system',
    description: 'We periodically send test documents through all nodes and compare outputs. If a node produces significantly different results, it\'s flagged for investigation.',
  },
  {
    title: 'Node certification',
    description: 'Nodes must meet technical and governance standards to join the network. Certification is periodic — not just at onboarding. Non-compliant nodes can be suspended.',
  },
];
---

<BaseLayout title="Community Network" description="A federated network of communities — independent but connected. See how prompt lock, cryptographic verification, and node certification keep the network honest.">
  <Hero
    title="Network"
    subtitle="A network of communities, not platforms. Each community runs their own instance—shaped by their needs, governed by their rules. But we're stronger together."
  />

  <Section
    title="How it works"
    subtitle="Each community is independent but connected. Improvements made by one flow to all."
  >
    <div class="bg-gray-50 rounded-lg p-6 font-mono text-xs text-slate-dark/80 overflow-x-auto">
      <pre>
california.opuspopuli.org ─┐
                                ├─── Shared Platform (upstream repo)
texas.opuspopuli.org ──────┤
                                │
newyork.opuspopuli.org ────┘</pre>
    </div>
  </Section>

  <Section
    title="Benefits"
    background="gray"
  >
    <div class="grid md:grid-cols-2 gap-8">
      {benefits.map(benefit => (
        <div>
          <h3 class="font-medium mb-1">{benefit.title}</h3>
          <p class="text-slate-dark/80 text-sm">{benefit.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section
    title="How the network stays honest"
    subtitle="A federated network is only as trustworthy as its weakest node. Here's how we solve the 'one bad apple' problem."
  >
    <div class="max-w-2xl space-y-6 text-slate-dark/80 mb-12">
      <p>
        Regions control what facts are available — their local data sources, their civic records, their meeting schedules. But no region can control how facts are interpreted. The analysis methodology is uniform across every node in the network. Learn more about our <a href="/transparency" class="underline underline-offset-2 hover:opacity-70 transition-opacity">AI trust commitments</a> and how <a href="/privacy" class="underline underline-offset-2 hover:opacity-70 transition-opacity">privacy is built into the architecture</a>.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      {trustMechanisms.map(m => (
        <div class="border-l-2 border-sage pl-6 py-2">
          <h3 class="text-base font-medium text-slate-dark mb-2">{m.title}</h3>
          <p class="text-slate-dark/80 text-sm leading-relaxed">{m.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section
    title="The trust equation"
    background="gray"
  >
    <div class="max-w-2xl">
      <div class="bg-white rounded-lg p-6 border border-slate-dark/10">
        <p class="text-sm text-slate-dark/80 leading-relaxed">
          <span class="font-medium text-slate-dark">Open source code</span> (verifiable) +
          <span class="font-medium text-slate-dark"> Consistent prompts</span> (uniform) +
          <span class="font-medium text-slate-dark"> Cryptographic attestation</span> (tamper-proof) =
          <span class="font-medium text-slate-dark"> Trustworthy analysis at scale</span>
        </p>
      </div>
      <p class="text-slate-dark/80 text-sm mt-6">
        Network rules are published in NETWORK.md and NETWORK-TERMS.md. Member requirements, data ownership, and termination rights are all documented and enforceable.
      </p>
    </div>
  </Section>

  <Section title="Members">
    {networkMembers.map(member => (
      <div class="flex items-center justify-between py-4 border-b border-slate-dark/5 last:border-0">
        <div>
          <span class="font-medium">{member.name}</span>
          <span class="text-slate-dark/80 text-sm ml-3">{member.note}</span>
        </div>
        <code class="text-xs text-slate-dark/80 bg-slate-dark/5 px-3 py-1 rounded-full">{member.subdomain}</code>
      </div>
    ))}

    <div class="mt-10">
      <a
        href="/get-involved"
        class="inline-flex items-center bg-slate-dark text-white border border-white px-5 py-2.5 rounded-md hover:bg-slate-dark/90 transition-colors text-sm font-medium"
      >
        Get Involved
      </a>
    </div>
  </Section>

  <Section background="dark">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold mb-4 tracking-tight">Community sovereignty</h2>
      <p class="text-white/70 mb-10">
        Being part of the network means gaining support—not giving up control.
      </p>

      <div class="grid sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-medium mb-1">Your data</h3>
          <p class="text-white/70 text-sm">Stays where you decide, always</p>
        </div>
        <div>
          <h3 class="font-medium mb-1">Your customizations</h3>
          <p class="text-white/70 text-sm">Shape it for your community's needs</p>
        </div>
        <div>
          <h3 class="font-medium mb-1">Your infrastructure</h3>
          <p class="text-white/70 text-sm">Run it where you want</p>
        </div>
        <div>
          <h3 class="font-medium mb-1">Your governance</h3>
          <p class="text-white/70 text-sm">Your community makes the decisions</p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

const supportingTools = [
  {
    title: 'Proposition Explorer',
    description: '47 pages of legal text become a 5-minute interactive summary — with fiscal impact, arguments for and against, and the full source text always one click away.',
    href: '/platform#proposition-explorer',
  },
  {
    title: 'Representative Directory',
    description: 'Enter your address. See every representative from city council to Congress — with bios, committee assignments, and built-in contact forms.',
    href: '/platform#representative-directory',
  },
  {
    title: 'Meeting Calendar',
    description: 'Every public legislative meeting in your jurisdiction, searchable by body — with agendas, minutes, and video links.',
    href: '/platform#meeting-calendar',
  },
  {
    title: 'Petition Scanner',
    description: 'Point your phone at a petition. Get an instant plain-language breakdown with automatic ballot measure matching.',
    badge: 'AI-Powered',
    href: '/platform#petition-scanner',
  },
  {
    title: 'Document Q&A',
    description: 'Upload any civic document. Ask questions in plain English. Get answers with citations — processed on the node serving your community.',
    badge: 'AI-Powered',
    href: '/platform#document-qa',
  },
];

const values = [
  {
    title: 'Public-domain data only',
    description: 'FEC, Congress.gov, Cal-Access. No commercially-restricted sources. An auditable provenance chain anyone can verify.',
  },
  {
    title: 'Open code, durable license',
    description: 'AGPL-3.0 with a dual commercial license. The civic commons stays open — mission drift is structurally constrained, not just promised.',
  },
  {
    title: 'Privacy by design',
    description: 'AI inference runs on the node serving your community. No third-party AI services. Location data is geo-fuzzed. Audit logs mask PII automatically.',
  },
  {
    title: 'Accessible to all',
    description: 'WCAG 2.2 AA compliant. Works offline as a progressive web app. English and Spanish.',
  },
];

const audiences = [
  {
    title: 'Citizens',
    description: 'Read the ballot in plain language. See who funded the campaign. Find your representative. Show up to the meeting. Send the email with the public record cited inline.',
    href: '/platform',
    linkText: 'See the Platform',
  },
  {
    title: 'Journalists & researchers',
    description: 'Cross-reference donor industries against voting records. Trace outside spending across measures. Query budget documents with citations.',
    href: '/network',
    linkText: 'Network Capabilities',
  },
  {
    title: 'Local operators',
    description: "Run a certified node serving your state, county, or city. Connect your jurisdiction's data sources through declarative config — no scraper code required.",
    href: '/get-involved',
    linkText: 'Operate a Node',
  },
];

const techStack = [
  { name: 'Next.js', url: 'https://nextjs.org' },
  { name: 'NestJS', url: 'https://nestjs.com' },
  { name: 'GraphQL Federation', url: 'https://graphql.org' },
  { name: 'PostgreSQL + pgvector', url: 'https://postgresql.org' },
  { name: 'Ollama', url: 'https://ollama.com' },
  { name: 'Prisma', url: 'https://prisma.io' },
  { name: 'Supabase', url: 'https://supabase.com' },
  { name: 'Docker', url: 'https://docker.com' },
  { name: 'Terraform', url: 'https://terraform.io' },
  { name: 'Cloudflare', url: 'https://cloudflare.com' },
];
---

<BaseLayout title="Make American Democracy Legible" description="Opus Populi is a federated civic transparency platform that maps the relationships between representatives, their donors, and their votes — built on public-domain civic data and open source under AGPL-3.0.">
  <Hero
    title="Make American democracy legible."
    subtitle="Lobbyists have researchers, analysts, and communications professionals to translate public records into actionable intelligence. Ordinary citizens do not. Opus Populi closes that gap — mapping the relationships between representatives, their donors, and their votes on a federated network whose architecture mirrors American government itself."
    ctaText="See the Platform"
    ctaHref="/platform"
    secondaryCtaText="View Source on GitHub"
    secondaryCtaHref="https://github.com/OpusPopuli/opuspopuli"
  />

  <Section
    id="problem"
    title="The data is public. The asymmetry is structural."
  >
    <div class="max-w-2xl space-y-5 text-slate-dark/80 leading-relaxed">
      <p>
        American democracy produces an extraordinary volume of public information — voting records, campaign finance disclosures, meeting minutes, ballot measure texts, personal financial disclosures — and then makes it practically inaccessible to the citizens it is meant to serve.
      </p>
      <p>
        The information asymmetry between professional lobbyists and ordinary citizens is not primarily a legal problem. The data is public. The asymmetry is structural: lobbyists employ researchers, analysts, and communications professionals to translate raw civic data into actionable intelligence. Citizens have no equivalent apparatus.
      </p>
      <p class="font-medium text-slate-dark">
        We're building that apparatus — and putting it in citizens' hands under an <a href="/open-source" class="underline underline-offset-2 hover:opacity-70 transition-opacity">open-source license that cannot be quietly closed</a>.
      </p>
    </div>
  </Section>

  <Section
    id="influence-graph"
    title="The Influence Graph"
    subtitle="Representative. Donors. Votes. Conflicts. One lens on the relationships that shape every law that touches your life."
    background="gray"
  >
    <div class="max-w-2xl space-y-5 text-slate-dark/80 leading-relaxed mb-10">
      <p>
        The Influence Graph is the platform's flagship view — an interactive map of who funds whom, who votes how, and where the alignment between donor industry and legislative outcome crosses from coincidence into pattern.
      </p>
      <p>
        Donors and PACs visualized by contribution size and industry. Voting records cross-referenced against donor industry through semantic matching on bill content. Conflict-of-interest arcs surfaced algorithmically when alignment exceeds threshold.
      </p>
      <p>
        It composes the underlying civic tools — proposition explorer, campaign finance tracker, representative directory, meeting calendar — into a single coherent view of how political money moves through American government.
      </p>
    </div>
    <a href="/platform#influence-graph" class="text-sm text-slate-dark/80 hover:text-slate-dark font-medium transition-colors">
      How the Influence Graph works &rarr;
    </a>
  </Section>

  <Section
    id="tools"
    title="The tools beneath the graph"
    subtitle="Each works on its own. Together they compose the Influence Graph."
  >
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <a href="/platform#campaign-finance" class="text-slate-dark border-l-2 border-sage pl-6 py-2 hover:opacity-80 transition-opacity">
        <div class="flex items-center gap-2 mb-1">
          <h3 class="font-medium">Campaign Finance Tracker</h3>
          <span class="text-xs bg-sage/15 text-sage-dark px-2 py-0.5 rounded-full font-medium">Graph core</span>
        </div>
        <p class="text-slate-dark/80 text-sm">See exactly who funded what initiative. Contributions, expenditures, and outside spending — aggregated from state and federal databases.</p>
      </a>
      {supportingTools.map(tool => (
        <a href={tool.href} class="text-slate-dark border-l-2 border-slate-dark/10 pl-6 py-2 hover:border-sage transition-colors">
          <div class="flex items-center gap-2 mb-1">
            <h3 class="font-medium">{tool.title}</h3>
            {tool.badge && (
              <span class="text-xs bg-sage/15 text-sage-dark px-2 py-0.5 rounded-full font-medium">{tool.badge}</span>
            )}
          </div>
          <p class="text-slate-dark/80 text-sm">{tool.description}</p>
        </a>
      ))}
    </div>
  </Section>

  <Section
    id="provenance"
    title="Built on the public record"
    subtitle="One commitment that cannot be quietly revised: every civic data source is public domain."
    background="gray"
  >
    <div class="max-w-2xl space-y-5 text-slate-dark/80 leading-relaxed">
      <p>
        Opus Populi's primary data sources — the Federal Election Commission, Congress.gov, and California's Cal-Access campaign finance database — are public domain. There is no downstream license to negotiate, no commercial reuse restriction to disclose, no provenance chain that breaks when a vendor changes terms.
      </p>
      <p>
        This is a deliberate strategic decision. A civic transparency platform that depends on commercially-restricted civic data inherits the restrictions of its sources. Anyone can audit our data provenance. Anyone can replicate our pipelines. Methodological openness is the platform's strongest legal and political protection.
      </p>
    </div>
  </Section>

  <Section
    id="values"
  >
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map(v => (
        <div>
          <h3 class="text-sm font-medium text-slate-dark mb-1">{v.title}</h3>
          <p class="text-slate-dark/70 text-sm">{v.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section
    id="federation"
    title="Architecture that mirrors the republic"
    subtitle="Federal, state, county, municipal. The data lives where the governance lives."
    background="gray"
  >
    <div class="max-w-2xl space-y-5 text-slate-dark/80 leading-relaxed mb-8">
      <p>
        Opus Populi is not a centralized platform layered on top of civic data. It is a federated network whose architecture intentionally mirrors the hierarchical structure of American democratic governance.
      </p>
      <p>
        A shared federal layer ingests Congress.gov and FEC data once. State nodes own their state legislative and campaign finance corpus. County and municipal operators progressively take over local jurisdictions as they come online.
      </p>
      <p>
        Federation produces cross-jurisdictional pattern intelligence — donor networks that span states, model legislation that spreads simultaneously, astroturfing patterns invisible from any single county — that emerges from the network itself. No centralized scraper can replicate it.
      </p>
    </div>
    <a href="/network" class="text-sm text-slate-dark/80 hover:text-slate-dark font-medium transition-colors">
      How the network works &rarr;
    </a>
  </Section>

  <Section
    id="who-its-for"
    title="Who it's for"
    subtitle="Built for the people and institutions that already make democracy work — and for the citizens they serve."
  >
    <div class="grid md:grid-cols-3 gap-8">
      {audiences.map(a => (
        <div class="border-l-2 border-sage pl-6 py-2">
          <h3 class="font-medium mb-2">{a.title}</h3>
          <p class="text-slate-dark/80 text-sm mb-4">{a.description}</p>
          <a href={a.href} class="text-sm text-slate-dark/80 hover:text-slate-dark font-medium transition-colors">
            {a.linkText} &rarr;
          </a>
        </div>
      ))}
    </div>
  </Section>

  <Section
    id="technology"
    title="Technology"
    subtitle="Built entirely with open-source components. No proprietary dependencies."
    background="gray"
  >
    <div class="flex flex-wrap gap-3">
      {techStack.map(tech => (
        <a
          href={tech.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-slate-dark/80 border border-slate-dark/10 px-4 py-2 rounded-full hover:border-sage hover:text-sage transition-colors"
        >
          {tech.name}
        </a>
      ))}
    </div>
  </Section>

  <Section background="dark">
    <div class="max-w-xl">
      <h2 class="text-2xl font-bold mb-4 tracking-tight">Build with us.</h2>
      <p class="text-white/70 mb-8">
        Whether you're a citizen, a newsroom, or a regional operator — the network grows by who shows up. Run a node. Contribute code. Add your jurisdiction. Make American democracy a little more legible.
      </p>
      <div class="flex gap-3">
        <a
          href="/get-involved"
          class="inline-flex items-center bg-sage-dark text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-sage-darker transition-colors text-sm"
        >
          Get Involved
        </a>
        <a
          href="/why"
          class="inline-flex items-center text-white/80 hover:text-white px-6 py-2.5 text-sm font-medium transition-colors"
        >
          Why It Matters
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>

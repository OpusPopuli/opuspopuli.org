---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  extraSchema?: Record<string, unknown>[];
}

const {
  title,
  description = 'Opus Populi - Open-source civic technology for engaged democracy',
  image = '/social/op-banner-light.png',
  extraSchema = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const isHomePage = Astro.url.pathname === '/';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Opus Populi',
  url: 'https://opuspopuli.org',
  logo: 'https://opuspopuli.org/logos/png/op-horizontal-dark.png',
  description: 'Open-source civic technology for engaged democracy',
  foundingDate: '2024',
  sameAs: [
    'https://github.com/OpusPopuli/opuspopuli',
    'https://medium.com/@opuspopuli',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hello@opuspopuli.org',
    contactType: 'general',
  },
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  knowsAbout: [
    'Civic technology',
    'Open source software',
    'Democracy',
    'Government transparency',
    'Campaign finance',
    'Ballot propositions',
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonicalURL.href,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://opuspopuli.org/' },
    ...(!isHomePage ? [{
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: canonicalURL.href,
    }] : []),
  ],
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Opus Populi',
  applicationCategory: 'GovernmentApplication',
  operatingSystem: 'Web',
  license: 'https://www.gnu.org/licenses/agpl-3.0.en.html',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A2332" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon-32.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="512x512" href="/favicons/favicon-512.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Opus Populi" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {isHomePage && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
    )}
    {extraSchema.map(schema => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <title>{title} | Opus Populi</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import Sunflower from './Sunflower.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/platform', label: 'Platform' },
  { href: '/about', label: 'About' },
  { href: '/why', label: 'Why' },
  { href: '/network', label: 'Network' },
  { href: '/open-source', label: 'Open Source' },
  { href: '/get-involved', label: 'Get Involved' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="bg-paper border-b border-border">
  <nav class="container mx-auto px-6 py-4 max-w-5xl">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group" aria-label="Opus Populi — home">
        <Sunflower state="idle" size={34} />
        <span class="flex flex-col leading-none">
          <span class="text-sm font-semibold tracking-[0.18em] uppercase text-ink">Opus Populi</span>
          <span class="font-display italic text-xs text-dim mt-1">The Work of the People</span>
        </span>
      </a>

      <ul class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'text-sm transition-colors',
                isActive(link.href)
                  ? 'text-ink font-semibold border-b-2 border-gold pb-0.5'
                  : 'text-ink/60 hover:text-ink border-b-2 border-transparent pb-0.5',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-ink/70"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden mt-6 pb-4 border-t border-border pt-6">
      <ul class="flex flex-col gap-4">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'block text-sm transition-colors',
                isActive(link.href)
                  ? 'text-ink font-semibold border-l-2 border-gold pl-3'
                  : 'text-ink/60 hover:text-ink border-l-2 border-transparent pl-3',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', String(!isExpanded));
    mobileMenu?.classList.toggle('hidden');
  });
</script>
